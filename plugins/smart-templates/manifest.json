{
  "id": "smart-templates",
  "name": "Smart Templates",
  "version": "1.0.0",
  "author": "Carbide Community",
  "description": "Context-aware dynamic templates with Handlebars, live preview, and one-click insertion.",
  "api_version": "1",
  "permissions": [
    "editor:read",
    "editor:modify",
    "metadata:read",
    "search:read",
    "events:subscribe",
    "commands:register",
    "ui:panel",
    "fs:read",
    "fs:write",
    "settings:register"
  ],
  "activation_events": ["on_startup"],
  "contributes": {
    "settings": [
      {
        "key": "template_folder",
        "type": "string",
        "label": "Template folder",
        "description": "Vault folder path for saved templates",
        "default": "templates"
      },
      {
        "key": "default_date_format",
        "type": "string",
        "label": "Default date format",
        "description": "Date format string (e.g. YYYY-MM-DD)",
        "default": "YYYY-MM-DD"
      },
      {
        "key": "preview_debounce",
        "type": "number",
        "label": "Preview debounce (ms)",
        "description": "Delay before preview updates after typing",
        "default": 1000
      }
    ]
  }
}
